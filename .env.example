# PaciFund Configuration
# Copy this to .env and fill in your values

# Pacifica API key (get from https://test-app.pacifica.fi)
PACIFICA_API_KEY=

# Use testnet (true) or mainnet (false)
USE_TESTNET=true

# Arb engine settings
MIN_SPREAD=0.0001
MAX_POSITION_PCT=0.25

# Database path
DB_PATH=data/pacifund.db
